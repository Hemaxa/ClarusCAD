#!/bin/sh
set -eu

APP_BUNDLE="$1"
OUTPUT_DMG="$2"
APP_NAME="$3"
MACDEPLOYQT="$4"
QT_LIB_DIR="${5:-}"
LIBPATH_ARG=""

WORK_DIR="$(dirname "$APP_BUNDLE")"
STAGE_DIR="$WORK_DIR/dmg-stage"

rm -rf "$STAGE_DIR" "$OUTPUT_DMG"
mkdir -p "$STAGE_DIR"

cd "$WORK_DIR"

rm -rf \
    "${APP_NAME}.app/Contents/Frameworks" \
    "${APP_NAME}.app/Contents/PlugIns" \
    "${APP_NAME}.app/Contents/Resources/qt.conf"

if [ -n "$QT_LIB_DIR" ] && [ -d "$QT_LIB_DIR" ]; then
    LIBPATH_ARG="-libpath=$QT_LIB_DIR"
fi

if [ -n "${MACOS_CODESIGN_IDENTITY:-}" ]; then
    if [ -n "${MACOS_NOTARY_ENABLED:-}" ]; then
        "$MACDEPLOYQT" "${APP_NAME}.app" -always-overwrite -verbose=1 ${LIBPATH_ARG:+$LIBPATH_ARG} -sign-for-notarization="${MACOS_CODESIGN_IDENTITY}"
    else
        "$MACDEPLOYQT" "${APP_NAME}.app" -always-overwrite -verbose=1 ${LIBPATH_ARG:+$LIBPATH_ARG} -codesign="${MACOS_CODESIGN_IDENTITY}" -hardened-runtime -timestamp
    fi
else
    "$MACDEPLOYQT" "${APP_NAME}.app" -always-overwrite -verbose=1 ${LIBPATH_ARG:+$LIBPATH_ARG}
fi

ditto "${APP_NAME}.app" "$STAGE_DIR/${APP_NAME}.app"
ln -s /Applications "$STAGE_DIR/Applications"

hdiutil create \
    -volname "$APP_NAME" \
    -srcfolder "$STAGE_DIR" \
    -ov \
    -format UDZO \
    "$OUTPUT_DMG"

if [ -n "${MACOS_CODESIGN_IDENTITY:-}" ]; then
    codesign --force --sign "${MACOS_CODESIGN_IDENTITY}" --timestamp "$OUTPUT_DMG"
fi

if [ -n "${MACOS_NOTARY_ENABLED:-}" ] && [ -n "${MACOS_NOTARY_PROFILE:-}" ]; then
    xcrun notarytool submit "$OUTPUT_DMG" --keychain-profile "${MACOS_NOTARY_PROFILE}" --wait
    xcrun stapler staple "$OUTPUT_DMG"
fi
