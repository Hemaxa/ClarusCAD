/*
    Тема ClarusCAD
    @iconColor: #00ff7f;
    @backgroundColor: #1e1e1e;
    @textColor: #e6efe9;
    @panelBackgroundColor: #2a2f2c;
    @borderColor: #3d4640;
    @accentColor: #00ff7f;
    @hoverColor: #343b37;
    @selectionColor: #00ff7f;
    @axisScaleColor: #8ea194;
    @drawingColor: #00ff7f;
*/

QMainWindow, QDialog {
    background-color: #1e1e1e;
    color: #e6efe9;
}

QWidget {
    color: #e6efe9;
    border: none;
    font-size: 13px;
}

QDockWidget {
    background-color: #2a2f2c;
}

QDockWidget::title {
    background-color: #2a2f2c;
    color: #e6efe9;
    padding: 6px 8px;
    border-radius: 4px;
    border-bottom: 1px solid #00ff7f;
}

QLabel#InfoLabel {
    background-color: rgba(42, 47, 44, 0.92);
    color: #e6efe9;
    padding: 5px;
    border-radius: 4px;
    border: 1px solid #3d4640;
    font-family: 'Monaco', 'Menlo', 'Courier New', monospace;
    font-size: 12px;
}

QToolTip {
    background-color: #2a2f2c;
    color: #e6efe9;
    border: 1px solid #3d4640;
    padding: 4px 6px;
}

QMenu {
    background-color: #2a2f2c;
    color: #e6efe9;
    border: 1px solid #3d4640;
}

QMenu::item {
    padding: 6px 12px;
}

QMenu::item:selected {
    background-color: #343b37;
    color: #00ff7f;
}

QToolButton {
    background-color: transparent;
    border: 1px solid #3d4640;
    border-radius: 4px;
    padding: 5px;
}

QToolButton:hover, QToolButton:checked {
    background-color: #343b37;
    border: 1px solid #00ff7f;
}

QPushButton {
    background-color: #2a2f2c;
    border: 1px solid #00ff7f;
    color: #00ff7f;
    padding: 5px 10px;
    border-radius: 4px;
}

QPushButton:hover {
    background-color: #00ff7f;
    color: #1e1e1e;
}

QPushButton:disabled {
    background-color: #262a28;
    border-color: #3d4640;
    color: #708077;
}

QLineEdit, QTextEdit, QPlainTextEdit,
QComboBox, QSpinBox, QDoubleSpinBox {
    background-color: #2a2f2c;
    color: #e6efe9;
    border: 1px solid #3d4640;
    border-radius: 6px;
    padding: 4px 6px;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus,
QComboBox:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #00ff7f;
}

QComboBox::drop-down {
    width: 18px;
    border: none;
    border-top-right-radius: 5px;
    border-bottom-right-radius: 5px;
    background-color: #00ff7f;
}

QSpinBox::up-button, QDoubleSpinBox::up-button,
QSpinBox::down-button, QDoubleSpinBox::down-button {
    width: 18px;
    border: none;
    background-color: #00ff7f;
}

QComboBox QAbstractItemView {
    background-color: #2a2f2c;
    color: #e6efe9;
    border: 1px solid #3d4640;
    selection-background-color: #00ff7f;
    selection-color: #1e1e1e;
    min-height: 180px;
    padding: 4px;
}

QListWidget {
    background-color: #1e1e1e;
    border-radius: 4px;
    border: 1px solid #3d4640;
}

QListWidget::item:hover {
    background-color: #343b37;
}

QListWidget::item:selected {
    background-color: #00ff7f;
    color: #1e1e1e;
}

QGroupBox {
    border: 1px solid #00ff7f;
    border-radius: 4px;
    margin-top: 1ex;
    font-weight: bold;
    padding-top: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    padding: 0 3px;
}

QLineEdit#PropertiesInput {
    min-width: 70px;
    max-width: 100px;
    min-height: 24px;
    max-height: 24px;
    padding: 2px 6px;
}

QComboBox#PropertiesComboBox {
    min-width: 120px;
    max-width: 220px;
    min-height: 24px;
    max-height: 24px;
    padding: 2px 6px;
}

BasePropertiesWidget QLineEdit,
SegmentPropertiesWidget QLineEdit,
CirclePropertiesWidget QLineEdit,
ArcPropertiesWidget QLineEdit,
EllipsePropertiesWidget QLineEdit,
RectanglePropertiesWidget QLineEdit,
PolygonPropertiesWidget QLineEdit,
SplinePropertiesWidget QLineEdit {
    min-width: 70px;
    max-width: 100px;
    min-height: 24px;
    max-height: 24px;
    padding: 2px 6px;
}

BasePropertiesWidget QComboBox,
CirclePropertiesWidget QComboBox,
RectanglePropertiesWidget QComboBox,
ArcPropertiesWidget QComboBox {
    min-width: 120px;
    max-width: 220px;
    min-height: 24px;
    max-height: 24px;
}

BasePropertiesWidget QPushButton {
    min-height: 28px;
}

BasePropertiesWidget QLabel {
    min-height: 20px;
}

QCheckBox {
    spacing: 5px;
}

QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 1px solid #3d4640;
    border-radius: 3px;
    background-color: #2a2f2c;
}

QCheckBox::indicator:checked {
    background-color: #00ff7f;
    border-color: #00ff7f;
}

QScrollArea {
    background-color: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

QScrollBar:vertical {
    border: none;
    background: #2a2f2c;
    width: 10px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #00ff7f;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    border: none;
    background: #2a2f2c;
    height: 10px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background: #00ff7f;
    border-radius: 5px;
    min-width: 20px;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

QTabWidget::pane {
    border: 1px solid #3d4640;
    border-bottom: 1px solid #00ff7f;
}

QTabBar::tab {
    background: #2a2f2c;
    color: #e6efe9;
    padding: 8px 12px;
    border: 1px solid #3d4640;
    margin-right: 2px;
}

QTabBar::tab:selected {
    background: #1e1e1e;
    color: #00ff7f;
    border-color: #00ff7f;
    border-top: 1px solid #1e1e1e;
}

QTabBar::tab:hover {
    background: #343b37;
}

QLabel#PatternPreviewLabel {
    color: #00ff7f;
    font-weight: bold;
}

QPushButton#ColorButton {
    border-radius: 12px;
    border: 1px solid #3d4640;
}
